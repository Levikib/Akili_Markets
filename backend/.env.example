# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL_SYNC=postgresql://user:password@host/dbname

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@host:6379

# ─── Deriv API ──────────────────────────────────────────────────────────────
DERIV_APP_ID=your-app-id-here
DERIV_API_TOKEN=a1-your-token-here

# ─── Groq AI ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=akili-markets-trader-secret-key-change-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Risk (hard limits — do not raise above these) ──────────────────────────
MAX_RISK_PER_TRADE_PCT=1.5
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=15.0
PAPER_MODE_DEFAULT=true
